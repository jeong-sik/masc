      "id": 1,
      "targets": [
        {
          "expr": "sum by (keeper_name) (rate(masc_keeper_turn_completed_total[5m])) / clamp_min(sum by (keeper_name) (rate(masc_keeper_turn_scheduled_total[5m])), 0.001)",
