# Lodge Heartbeat Configuration
# Loaded by start-masc-mcp.sh at startup

# Tick interval (seconds) — 14400 = 4 hours
MASC_LODGE_TICK_INTERVAL_SEC=14400

# Max agents to activate per tick
MASC_LODGE_AGENTS_PER_TICK=3

# Use planner-based selection (false = legacy least-recent)
MASC_LODGE_USE_PLANNER=false

# Quiet hours (KST) — agents don't act during this window
LODGE_QUIET_START=3
LODGE_QUIET_END=7

# Min gap between same agent check-ins (seconds)
# LODGE_MIN_CHECKIN_GAP=1800
