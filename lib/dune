   masc_mcp.cdal_runtime
   ;; RFC-0056 Phase 0 — CDAL Phase 1A evaluator extracted to lib/cdal/
   ;; as its own sub-library. Hosts Cdal_types + Adversarial_eval +
   ;; Labeling. Phase 1 will move judge / eval_v1 / loader once their
   ;; root-namespace cycles (Proof_artifact_reader, Bounded, Session,
   ;; Attribution, Violation_record) are resolved.
   masc_mcp.cdal
   ;; RFC-0056 Phase 1A — Trajectory leaf module promoted out of flat
   ;; masc_mcp namespace. Unblocks Wave A keeper/server godfile extractions
   ;; (PR-1+) by removing the parent ↔ sub-lib cycle on `Trajectory.X`.
   ;; (wrapped false) preserves the bare `Trajectory` identifier; only
   ;; wrapped-pattern callers (Masc_mcp.Trajectory.X in tests) drop prefix.
   masc_mcp.trajectory
   ;; RFC-0056 Phase 1B — Keeper_skill_routing leaf utility extracted to
   ;; lib/keeper_skill_routing/. 215 LoC, only stdlib + masc_core deps.
   ;; First step in unblocking lib/keeper/ flat-namespace decoupling.
   masc_mcp.keeper_skill_routing
   ;; RFC-0056 Phase 1C — Host_config leaf module extracted to
   ;; lib/host_config/. RFC-0084 §1.5/§3.4 typed host configuration record;
   ;; deps: stdlib + masc_mcp.coord (already sub-library).
   masc_mcp.host_config
   ;; RFC-0056 Phase 1D — Briefing_compactors leaf module extracted to
   ;; lib/briefing_compactors/. 174+21 LoC, deps: stdlib + Yojson +
   ;; masc_mcp.masc_types (Masc_domain). Was previously in
   ;; (private_modules); promotion preserves internal-only access.
   masc_mcp.briefing_compactors
   ;; RFC-0056 Phase 1E — Dashboard_eval_feed leaf module extracted to
   ;; lib/dashboard_eval_feed/. 178+59 LoC, deps: stdlib + Yojson +
   ;; agent_sdk + masc_core (Json_util/Safe_ops).
   masc_mcp.dashboard_eval_feed
   ;; RFC-0004 Phase A0.1 PR-1 — Typed SSE event lib (lib/sse_event/).
   ;; atdgen-generated payload types + hand-rolled envelope wrap that
   ;; mirrors cascade_event_bridge.wrap_event/json_string_opt
   ;; semantics.  PR-2 onwards: cascade_event_bridge arms call into
   ;; Sse_event.<event>_constructor instead of inline `Assoc.
   masc_mcp.sse_event
   ;; RFC-0056 Phase 1F — Memory_jsonl leaf module extracted to
   ;; lib/memory_jsonl/. 219+22 LoC, deps: stdlib + Yojson + Eio +
   ;; agent_sdk + fs_compat + time_compat + masc_log. OAS Memory
   ;; long_term_backend over JSONL files.
   masc_mcp.memory_jsonl
   ;; RFC-0056 Phase 1G — Chronicle_event leaf module extracted to
   ;; lib/chronicle_event/. 460+170 LoC, deps: stdlib + Yojson only.
   ;; Chronicle wire format (Actor / Target / Content / Event records
   ;; + to_yojson / of_yojson serializers).
   masc_mcp.chronicle_event
   ;; RFC-0056 Phase 1H — Tool_call_quality_benchmark + scoring closure
   ;; extracted to lib/tool_call_quality_benchmark/. 8 modules, ~2065 LoC,
   ;; deps: stdlib + Yojson + masc_core + time_compat. Bundles benchmark
   ;; family (6) + reward_advice_artifact + post_verifier to break the
   ;; Reward_advice_artifact ↔ Tool_call_quality_benchmark_types cycle.
   masc_mcp.tool_call_quality_benchmark
   ;; RFC-0056 Phase 1I — Keeper_event_queue (first lib/keeper/ leaf)
   ;; extracted to lib/keeper_event_queue/. 91+87 LoC, deps: stdlib +
   ;; Unix only. Pure data structure (urgency variants + FIFO + dedup)
   ;; backed by specs/keeper-state-machine/KeeperEventQueue.tla.
   ;; Referenced by keeper_supervisor + keeper_registry godfiles.
   masc_mcp.keeper_event_queue
   ;; RFC-0056 Phase 1J — Keeper_invariant (second lib/keeper/ leaf)
   ;; extracted to lib/keeper_invariant/. 119+77 LoC, stdlib-only
   ;; (List/Printf/Set/String/StringSet/Result). Fan-in: 1 lib + 1 test.
   masc_mcp.keeper_invariant
   ;; RFC-0056 Phase 1K — Compaction_trigger (third lib/keeper/ leaf)
   ;; extracted to lib/compaction_trigger/. 94+45 LoC, deps: stdlib +
   ;; Yojson + masc_log. Compaction trigger heuristic + JSON serializer.
   masc_mcp.compaction_trigger
   ;; RFC-0086 Phase 2.B prereq — Tool_catalog_surfaces (lib/ root, 554+103 LoC)
   ;; extracted to lib/tool_catalog_surfaces/. deps: Agent_sdk + stdlib only.
   ;; Unblocks one of 6 cycle modules identified in plan §8.14 iter-2.
   masc_mcp.tool_catalog_surfaces
   ;; RFC-0086 Phase 2.B prereq — Config_dir_resolver (lib/ root, 563+156 LoC)
   ;; extracted to lib/config_dir_resolver/. deps: masc_core (Common) +
   ;; masc_mcp.config (Env_config_core) + masc_mcp.host_config + masc_log + yojson.
   ;; Unblocks one of 6 cycle modules identified in plan §8.14 iter-2.
   masc_mcp.config_dir_resolver
   ;; RFC-0058 Phase 1 — Declarative cascade TOML config. Separate sub-library
   ;; to avoid type name collisions (transport, provider, binding, tier, strategy)
   ;; with identically-named types in the main library.
   masc_mcp.cascade_decl
   ;; RFC-0086 Phase 2.B prereq — Cascade_ref (lib/cascade/, 260+115 LoC)
   ;; extracted to lib/cascade_ref/. Deps: yojson only (stdlib + Yojson.Safe).
