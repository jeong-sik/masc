{
  "id": "native-smoke",
  "name": "Native Chain Smoke",
  "description": "Tool-only smoke chain for native MASC chain runtime verification",
  "version": "1.0.0",
  "config": {
    "timeout": 30,
    "max_concurrency": 1,
    "trace": true
  },
  "nodes": [
    {
      "id": "echo-start",
      "type": "tool",
      "name": "echo",
      "args": {
        "input": "native-chain-smoke"
      },
      "output_key": "echo_output"
    },
    {
      "id": "pack-result",
      "type": "tool",
      "name": "identity",
      "depends_on": ["echo-start"],
      "args": {
        "status": "ok",
        "echo": "{{echo_output}}",
        "runtime": "native"
      },
      "output_key": "final_result"
    }
  ],
  "output": "pack-result",
  "output_schema": {
    "type": "object",
    "properties": {
      "status": { "type": "string" },
      "echo": { "type": "string" },
      "runtime": { "type": "string" }
    }
  },
  "metadata": {
    "tags": ["smoke", "native", "tool-only"],
    "estimated_duration_sec": 5,
    "estimated_cost_usd": 0.0
  }
}
