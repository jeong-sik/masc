(include_subdirs no)

;; Thompson_sampling — Beta-distribution agent selection with starvation
;; prevention and vote/quality feedback. Carved out of the masc
;; mega-library so the Board domain can depend on Thompson_sampling.record_vote
;; without forcing a Board <-> mega-lib cycle.
;;
;; Thompson depends only on the neutral libraries below. Selection records
;; outcomes; historical health observations do not gate participation.
;;
;; Tool_call_quality_benchmark (used by [record_quality_signal]) is NOT a
;; mega-lib edge — it already lives in the leaf masc.tool_call_quality_benchmark
;; library (deps: yojson + masc_core + time_compat, no cycle back to Thompson),
;; so it is kept as a normal library dependency rather than callback-inverted.
;;
;; (wrapped false) keeps the bare `Thompson_sampling` module name so call
;; sites stay `Thompson_sampling.*`.

(library
 (name masc_thompson)
 (public_name masc.masc_thompson)
 (wrapped false)
 (libraries
  masc_core
  masc_config
  masc_log
  masc_workspace
  fs_compat
  time_compat
  masc.tool_call_quality_benchmark
  yojson
  eio))
