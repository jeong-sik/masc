{
  "id": "rumor-propagation-v1",
  "title": "Cathedral Rumor Diffusion",
  "type": "rumor",
  "description": "A seeded rumor spreads through actors; distortion and source recall are measured.",
  "roles": [
    { "id": "dm", "kind": "dm", "keeper": "dm" },
    { "id": "node-1", "kind": "player", "keeper": "ai-zealot" },
    { "id": "node-2", "kind": "player", "keeper": "best-programmer" },
    { "id": "node-3", "kind": "player", "keeper": "cassandra" }
  ],
  "runtime": {
    "seed": 77,
    "max_rounds": 10,
    "turn_timeout_sec": 90,
    "retry_per_turn": 1,
    "dm_control_default": "keeper",
    "allow_human_dm_override": true
  },
  "state_machine": [
    "lobby",
    "briefing",
    "round",
    "resolution",
    "end"
  ],
  "metrics": [
    {
      "key": "spread_depth",
      "label": "Spread Depth",
      "source": "event_graph",
      "formula_hint": "max shortest path from source"
    },
    {
      "key": "spread_breadth",
      "label": "Spread Breadth",
      "source": "event_graph",
      "formula_hint": "unique reached actors"
    },
    {
      "key": "source_recall_rate",
      "label": "Source Recall Rate",
      "source": "event_aggregate",
      "formula_hint": "mentions of original source / total retells"
    },
    {
      "key": "distortion_score",
      "label": "Distortion Score",
      "source": "semantic_distance",
      "formula_hint": "distance(seed_message, current_message)"
    }
  ],
  "viewer": {
    "default_panels": [
      "timeline",
      "turn_hud",
      "diffusion_graph",
      "distortion_line",
      "reach_heatmap"
    ],
    "graph": {
      "node": "actor",
      "edge": "rumor_transmission",
      "weight_field": "distortion_delta"
    }
  },
  "stop_conditions": [
    "max_rounds_exceeded",
    "diffusion_stalled_for_2_rounds",
    "manual_abort"
  ]
}
