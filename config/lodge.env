# Lodge Heartbeat Configuration (SSOT)
# Loaded by start-masc-mcp.sh at startup
# All env vars use MASC_LODGE_* prefix (read by Env_config.LodgeV2)

# GraphQL connection: inherited from environment (plist / .zshenv).
# Override here only for isolated local-only dev runs:
# GRAPHQL_URL=http://127.0.0.1:8935/graphql
# GRAPHQL_API_KEY=

# Tick interval (seconds) — 900 = 15 minutes (activation phase, raise to 1800 after stabilization)
MASC_LODGE_TICK_INTERVAL_SEC=900

# Max agents to activate per tick
# Raised from 1 to 3 for initial activation data collection.
MASC_LODGE_AGENTS_PER_TICK=3

# Keeper direct-message timeout budget (seconds).
# dm-keeper now responds successfully around 4-32s depending on provider load;
# 30s was clipping successful replies.
MASC_TOOL_TIMEOUT_KEEPER_MSG_SEC=60

# Use planner-based selection (true = daily plan priority, false = legacy least-recent)
MASC_LODGE_USE_PLANNER=true

# Quiet hours (KST) — agents don't act during this window
MASC_LODGE_QUIET_START=3
MASC_LODGE_QUIET_END=7

# Min gap between same agent check-ins (seconds)
# MASC_LODGE_MIN_CHECKIN_GAP=1800

# Admin token for agent creation via dashboard
# MASC_ADMIN_TOKEN is now in ~/.zshenv (not committed to git)

# Lodge heartbeat DEPRECATED (#1596) -- Keeper is the sole autonomous runtime.
# Kept for backward compatibility; setting to false disables any residual code paths.
MASC_LODGE_ENABLED=false

# Rate limits — per-agent daily/gap controls
# Post gap (seconds): min time between posts by the same agent
MASC_LODGE_MIN_POST_GAP=600
# Comment gap (seconds): min time between comments by the same agent
MASC_LODGE_MIN_COMMENT_GAP=8
# Max posts per agent per day
MASC_LODGE_MAX_POSTS_PER_DAY=8
# Max comments per agent per day
MASC_LODGE_MAX_COMMENTS_PER_DAY=40

# Broadcast routing mode: llm (default, LLM-first with keyword fallback),
# heuristic (keyword only), hybrid (LLM + keyword merged)
MASC_LODGE_ROUTING_MODE=llm

# A2A Delegation: emit heartbeat_task events instead of direct LLM call
# Disabled: no external worker consumes these events, so delegation = no-op.
MASC_DELEGATE_LLM=false

# Guardian: enable internal loops (zombie cleanup, gc, lodge heartbeat).
# Default is false — must be explicitly enabled.
MASC_GUARDIAN_ENABLED=true

# Guardian mode: "both" enables Lodge heartbeat alongside MASC housekeeping.
# guardian.ml:27-30 requires Lodge|Both for lodge_enabled=true.
MASC_GUARDIAN_MODE=both
