; RFC-0054 POC — codegen approach to walker generation.
;
; Layout:
;   synthetic_command.ml      — hand-written GADT type decl
;   synthetic_walkers.ml      — auto-generated by bin/poc_shell_ir_gen
;   test_synthetic_walkers.ml — consumer test, asserts walkers behave
;
; Pattern: dune (rule ...) runs the generator at build time and writes
; the .ml file. OCaml's standard parser handles the result — no ppxlib
; involvement, so the AST-vs-source divergence that blocked PPX cannot
; manifest here.

(rule
 (target synthetic_walkers.ml)
 (deps (:gen %{exe:../../bin/poc_shell_ir_gen.exe}))
 (action (with-stdout-to %{target} (run %{gen}))))

(test
 (name test_synthetic_walkers)
 (modules synthetic_command synthetic_walkers test_synthetic_walkers))
