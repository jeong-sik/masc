build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/jeong-sik/masc.git"
pin-depends: [
  [
  "agent_sdk.0.210.0"
  "git+https://github.com/jeong-sik/oas.git#c63bbf0175cd60984b8613dcce2950a29c930259"
]
  [
    "bisect_ppx.2.8.3"
    "git+https://github.com/patricoferris/bisect_ppx.git#5.2"
  ]
  [
  "grpc-direct.0.2.6"
  "git+https://github.com/jeong-sik/grpc-direct.git#d7269ebebf9e4688486cc6591c66e794607e7b0f"
]
  [
  "grpc-direct-core.0.2.6"
  "git+https://github.com/jeong-sik/grpc-direct.git#d7269ebebf9e4688486cc6591c66e794607e7b0f"
]
  [
    "mcp_protocol.1.3.0"
    "git+https://github.com/jeong-sik/mcp-protocol-sdk.git#v1.3.0"
  ]
  [
    "ocaml-webrtc.0.2.6"
    "git+https://github.com/jeong-sik/ocaml-webrtc.git#1b7993605b293f45169369d488f970ba15132a9f"
  ]
  [
  "ws-direct-core.0.1.0"
  "git+https://github.com/jeong-sik/ws-direct.git#88f325956e8d03e5d68838145ada08a19e221c42"
]
  [
  "ws-direct-eio.0.1.0"
  "git+https://github.com/jeong-sik/ws-direct.git#88f325956e8d03e5d68838145ada08a19e221c42"
]
  [
  "ws-direct-gluten.0.1.0"
  "git+https://github.com/jeong-sik/ws-direct.git#88f325956e8d03e5d68838145ada08a19e221c42"
]
]
x-maintenance-intent: ["(latest)"]
