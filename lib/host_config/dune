; RFC-0056 Phase 1C — extract Host_config leaf module from flat
; masc namespace.
;
; Host_config is dependency-leaf: stdlib (Filename, Format, String,
; Sys, Unix) + Workspace (already its own sub-library). Authored under
; RFC-0084 §1.5 + §3.4 as the typed host configuration record for
; keeper-tool dispatch portability.
;
; (include_subdirs no) opts out of parent's (include_subdirs unqualified).
; (wrapped false) keeps the top-level identifier `Host_config` unchanged.

(include_subdirs no)

(library
 (name masc_host_config)
 (public_name masc.host_config)
 (wrapped false)
 (flags
  (:standard -w +4))
 (preprocess
  (pps ppx_deriving.show ppx_deriving.eq))
 (libraries
  unix
  ; RFC-0085 PR-9 — Host_config absorbs base_path normalisation
  ; (previously Env_config_core.base_path_opt) so callers get a single
  ; SSOT for the normalised env-derived base_path.  The masc_workspace
  ; dep was unused (audit 2026-05-15) so it is dropped here, making
  ; Host_config a true leaf below masc_workspace.  Reverse migration of
  ; workspace_utils_backend_setup callers becomes possible because
  ; masc_workspace can now depend on masc.host_config without cycling.
  masc.config
  ; RFC-0121: derive .masc/<sub> paths via Common helpers. We cannot
  ; depend on masc.config_dir_resolver here because the resolver
  ; itself depends on host_config for test-mode + env reads.
  masc_core))
