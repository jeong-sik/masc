; RFC v5 Phase A0 — typed IR for local exec gate.
; Internal sub-library of masc_mcp.  No public name.
(include_subdirs no)
(library
 (name masc_exec)
 (public_name masc_mcp.masc_exec)
 (wrapped true)
 ; RFC-0071 §3.4 Phase 5 ratchet: warning 4 (fragile pattern match) on.
 (flags (:standard -w +4))
 (libraries masc_process masc_core masc_config eio unix yojson re))

; RFC-0054 PR-3 — auto-generate parallel-verification walkers for
; Shell_ir_typed. The generator's spec lives in
; bin/gen_shell_ir_walkers.ml; the generated file is included in this
; library automatically because (modules) is unspecified.
(rule
 (target shell_ir_typed_walkers_gen.ml)
 (deps (:gen %{exe:../../bin/gen_shell_ir_walkers.exe}))
 (action (with-stdout-to %{target} (run %{gen}))))
