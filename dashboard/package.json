{
  "name": "masc-dashboard",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.31.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "MASC_DASHBOARD_PROXY_TARGET=http://127.0.0.1:8935 vite",
    "build": "vite build",
    "build:report": "BUNDLE_REPORT=1 vite build",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts --no-file-parallelism --maxWorkers=1 && vitest run --config vitest.solid.config.ts --no-file-parallelism --maxWorkers=1",
    "test:serial": "pnpm test",
    "test:watch": "vitest",
    "tokens:build": "tsx design-system/tokens/build.ts",
    "tokens:check": "node design-system/tokens/scripts/check-equivalence.mjs"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.9.0",
    "@preact/signals": "^2.9.0",
    "cytoscape": "^3.33.2",
    "dompurify": "^3.4.0",
    "downshift": "^9.3.2",
    "htm": "^3.1.1",
    "lucide-preact": "^1.8.0",
    "marked": "^18.0.2",
    "mermaid": "^11.14.0",
    "ninja-keys": "^1.2.2",
    "preact": "^10.29.1",
    "shiki": "^4.0.2",
    "solid-js": "^1.9.5",
    "valibot": "^1.3.1",
    "vis-data": "^8.0.3",
    "vis-network": "^10.0.2",
    "vis-timeline": "^8.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@types/cytoscape": "^3.31.0",
    "@types/hammerjs": "^2.0.46",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.10.5",
    "culori": "^4.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "jest-axe": "^9.0.0",
    "postcss": "^8.5.6",
    "@solidjs/testing-library": "^0.8.10",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "vite-plugin-solid": "^2.11.6",
    "tsx": "^4.20.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "lodash-es": "^4.18.1"
    }
  }
}
