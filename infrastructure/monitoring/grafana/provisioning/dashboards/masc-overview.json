    {
      "id": 2,
      "type": "timeseries",
      "title": "Eio Loop Lag",
      "gridPos": {
        "x": 0,
        "y": 128,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "P4169E866C3094E38"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1.0
              },
              {
                "color": "red",
                "value": 5.0
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "max_over_time(masc_eio_loop_lag_seconds[1m])",
          "legendFormat": "lag",
          "refId": "A"
        }
