{
  "id": "negotiation-v1",
  "title": "Triple-Faction Ceasefire Negotiation",
  "type": "negotiation",
  "description": "Three factions must negotiate a ceasefire under scarcity and mistrust.",
  "roles": [
    { "id": "dm", "kind": "dm", "keeper": "dm" },
    { "id": "faction-a", "kind": "player", "keeper": "ai-zealot" },
    { "id": "faction-b", "kind": "player", "keeper": "best-programmer" },
    { "id": "faction-c", "kind": "player", "keeper": "cassandra" }
  ],
  "runtime": {
    "seed": 42,
    "max_rounds": 8,
    "turn_timeout_sec": 120,
    "retry_per_turn": 1,
    "dm_control_default": "keeper",
    "allow_human_dm_override": true
  },
  "state_machine": [
    "lobby",
    "briefing",
    "round",
    "resolution",
    "end"
  ],
  "metrics": [
    {
      "key": "agreement_rate",
      "label": "Agreement Rate",
      "source": "event_aggregate",
      "formula_hint": "agreements / proposals"
    },
    {
      "key": "rounds_to_agreement",
      "label": "Rounds To Agreement",
      "source": "state_transition",
      "formula_hint": "first agreement round index"
    },
    {
      "key": "coalition_switch_count",
      "label": "Coalition Switch Count",
      "source": "relationship_change",
      "formula_hint": "sum of alliance edge changes"
    }
  ],
  "viewer": {
    "default_panels": [
      "timeline",
      "turn_hud",
      "party_cards",
      "metrics_chart",
      "relationship_graph"
    ],
    "graph": {
      "node": "actor",
      "edge": "alliance_or_hostility",
      "weight_field": "trust_delta"
    }
  },
  "stop_conditions": [
    "agreement_reached",
    "max_rounds_exceeded",
    "manual_abort"
  ]
}
