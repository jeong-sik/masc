{
  "id": "trust-public-goods-v1",
  "title": "Sanctioned Commons Game",
  "type": "trust",
  "description": "Players contribute to a public pool, then vote sanctions on free riders.",
  "roles": [
    { "id": "dm", "kind": "dm", "keeper": "dm" },
    { "id": "player-1", "kind": "player", "keeper": "ai-zealot" },
    { "id": "player-2", "kind": "player", "keeper": "best-programmer" },
    { "id": "player-3", "kind": "player", "keeper": "cassandra" }
  ],
  "runtime": {
    "seed": 108,
    "max_rounds": 12,
    "turn_timeout_sec": 120,
    "retry_per_turn": 1,
    "dm_control_default": "keeper",
    "allow_human_dm_override": true
  },
  "rules": {
    "initial_tokens_per_player": 10,
    "pool_multiplier": 1.6,
    "sanction_enabled": true,
    "sanction_cost": 1,
    "sanction_damage": 2
  },
  "state_machine": [
    "lobby",
    "briefing",
    "round",
    "resolution",
    "end"
  ],
  "metrics": [
    {
      "key": "avg_contribution_rate",
      "label": "Average Contribution Rate",
      "source": "event_aggregate",
      "formula_hint": "sum(contribution) / max_possible_contribution"
    },
    {
      "key": "free_rider_ratio",
      "label": "Free Rider Ratio",
      "source": "event_aggregate",
      "formula_hint": "players with contribution<threshold / total players"
    },
    {
      "key": "sanction_frequency",
      "label": "Sanction Frequency",
      "source": "event_aggregate",
      "formula_hint": "sanction events / round count"
    },
    {
      "key": "cooperation_stability_index",
      "label": "Cooperation Stability Index",
      "source": "time_series",
      "formula_hint": "1 - variance(contribution_rate_by_round)"
    }
  ],
  "viewer": {
    "default_panels": [
      "timeline",
      "turn_hud",
      "resource_board",
      "contribution_stacked",
      "trust_matrix"
    ],
    "graph": {
      "node": "actor",
      "edge": "trust_or_sanction",
      "weight_field": "relation_delta"
    }
  },
  "stop_conditions": [
    "max_rounds_exceeded",
    "cooperation_stability_reached",
    "manual_abort"
  ]
}
