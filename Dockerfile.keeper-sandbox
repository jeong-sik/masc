FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      bash \
      ca-certificates \
      coreutils \
      findutils \
      git \
      gh \
      jq \
      make \
      nodejs \
      npm \
      opam \
      ocaml-dune \
      python3 \
      ripgrep \
      tree \
 && rm -rf /var/lib/apt/lists/*

CMD ["/bin/bash"]
